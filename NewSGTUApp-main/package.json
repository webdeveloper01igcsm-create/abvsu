{
  "name": "sgtu",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "private": true,
  "scripts": {
    "start": "expo start",
    "android": "set \"NODE_ENV=development\" && expo run:android",
    "android:apk:debug": "set \"NODE_ENV=development\" && cd android && gradlew.bat assembleDebug",
    "android:apk:release": "set \"NODE_ENV=development\" && cd android && gradlew.bat assembleRelease",
    "android:aab:release": "set \"NODE_ENV=development\" && cd android && gradlew.bat bundleRelease",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "eas:apk": "eas build -p android --profile preview",
    "eas:aab": "eas build -p android --profile production",
    "test": "jest --watchAll",
    "lint": "expo lint"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-picker/picker": "2.11.1",
    "@react-navigation/native": "^7.0.2",
    "axios": "^1.7.9",
    "buffer": "^6.0.3",
    "expo": "54.0.2",
    "expo-constants": "~18.0.8",
    "expo-device": "~8.0.7",
    "expo-document-picker": "~14.0.7",
    "expo-file-system": "~19.0.12",
    "expo-image-picker": "~17.0.8",
    "expo-linking": "~8.0.8",
    "expo-notifications": "~0.32.11",
    "expo-print": "~15.0.7",
    "expo-router": "~6.0.1",
    "expo-secure-store": "~15.0.7",
    "expo-splash-screen": "~31.0.9",
    "moment": "^2.30.1",
    "nativewind": "^4.1.23",
    "react": "19.1.0",
    "react-dom": "^19.1.0",
    "react-native": "0.81.4",
    "react-native-reanimated": "~4.1.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.1",
    "react-native-webview": "^13.16.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/jest": "^29.5.12",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "^54.0.0",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~10.0.0",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.10",
    "react-test-renderer": "19.1.0",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.2"
  }
}
